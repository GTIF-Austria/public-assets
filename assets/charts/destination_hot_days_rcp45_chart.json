      "type": "temporal",
      "title": "Time"
    },
    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Mean Hot Days"
    },
    "color": {
      "field": "feature_label",
      "type": "nominal",
      "title": "Region (Elevation)"
    },
    "tooltip": [
      {"field": "feature_label", "title": "Region (Elevation)"},
      {"field": "date", "type": "temporal", "title": "Date", "format": "%b %Y"},
      {"field": "value", "type": "quantitative", "title": "Mean", "format": ".2f"}
    ]
