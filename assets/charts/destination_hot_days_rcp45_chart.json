    },
    {
      "filter": "isValid(datum.value) && datum.value != null"
    },
    {
      "calculate": "split(datum.metric, '_')[0]",
      "as": "start_year_raw"
    },
    {
      "calculate": "toNumber(substring(datum.start_year_raw, 1))",
      "as": "start_year"
    },
    {
      "calculate": "split(datum.metric, '_')[1]",
      "as": "end_year"
    },
    {
      "calculate": "substring(datum.start_year_raw, 1) + '_' + datum.end_year",
      "as": "decade_label"
    },
    {
      "calculate": "split(datum.metric, '_')[2]",
      "as": "month_str"
    },
    {
      "calculate": "datetime(datum.start_year, indexof(['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'], datum.month_str), 1)",
      "as": "date"
    },
    {
      "calculate": "datum.tourism_region + ' (' + datum.elevation + ')'",
      "as": "feature_label"
    }
  ],
