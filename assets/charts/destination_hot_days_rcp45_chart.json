      "as": "year"
    },
    {
      "calculate": "split(datum.metric, '_')[2]",
      "as": "month_str"
    },
    {
      "calculate": "datetime(datum.year, indexof(['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'], datum.month_str), 1)",
      "as": "date"
    },
    {
      "calculate": "datum.tourism_region + ' (' + datum.elevation + ')'",
